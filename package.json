{
  "name": "tenra-facet",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "bootstrap": "./scripts/bootstrap.sh",
    "check:env": "./scripts/check-env.sh",
    "check:packages": "./scripts/check-packages.sh",
    "dev:web": "./scripts/dev-web.sh",
    "dev:desktop": "./scripts/dev-desktop.sh",
    "dev:mobile": "./scripts/dev-mobile.sh",
    "dev:both": "./scripts/dev-both.sh",
    "build:web": "pnpm --filter @facet/webapp build",
    "build:desktop": "pnpm --filter @facet/desktopapp build",
    "package:desktop": "pnpm --filter @facet/desktopapp exec tauri build --bundles app",
    "install:desktop": "pnpm run package:desktop && bash ./scripts/install-desktop-app.sh",
    "launch:desktop": "open -n \"/Applications/tenra Facet.app\"",
    "build:mobile": "pnpm --filter @facet/mobileapp build",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify:web": "./scripts/verify-web.sh",
    "verify:desktop": "./scripts/verify-desktop.sh",
    "verify:mobile": "./scripts/verify-mobile.sh",
    "verify:handoffs": "node ./scripts/validate-handoffs.mjs",
    "verify:all": "./scripts/verify-all.sh && pnpm run audit:maintainability && pnpm run budget:bundle",
    "doctor": "./scripts/doctor.sh",
    "analyze:bundle": "node scripts/analyze-build.mjs",
    "budget:bundle": "node scripts/analyze-build.mjs --strict",
    "audit:maintainability": "node scripts/audit-maintainability.mjs --strict"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.1.6",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
