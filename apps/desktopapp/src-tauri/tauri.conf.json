{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Facet by Tenra",
  "version": "0.1.0",
  "identifier": "co.tenra.facet",
  "build": {
    "beforeDevCommand": "pnpm --filter @facet/desktopapp dev",
    "beforeBuildCommand": "pnpm --filter @facet/desktopapp build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Facet by Tenra",
        "width": 1200,
        "height": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
