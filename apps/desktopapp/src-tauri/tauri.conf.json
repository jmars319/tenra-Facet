{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Facet",
  "version": "0.1.0",
  "identifier": "com.jamarq.facet",
  "build": {
    "beforeDevCommand": "pnpm --filter @facet/desktopapp dev",
    "beforeBuildCommand": "pnpm --filter @facet/desktopapp build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Facet",
        "width": 1200,
        "height": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity"
  }
}
